rules_version = '2';

// =============================================================================
// FIXLab — Firestore Security Rules (database: "fixlab") — Fase 2 multi-archivio
//
// Isolamento tenant: campo `studioId` + membership memberships/{userId}_{studioId}.
// Super Admin: custom claim superAdmin === true (accesso globale).
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return signedIn() && (
        request.auth.token.superAdmin == true
        || request.auth.token.email == 'studio@gmail.com'
        || request.auth.token.email == 'samuelelazzaro78@gmail.com'
      );
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userDocPath());
    }

    function memberStudioId() {
      return get(userDocPath()).data.studioId;
    }

    function membershipDocPath(studioId) {
      return /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + studioId);
    }

    function isMemberOfStudio(studioId) {
      return signedIn() && exists(membershipDocPath(studioId));
    }

    function isLegacyPrimaryStudio(studioId) {
      return userExists() && memberStudioId() == studioId;
    }

    function canAccessStudio(studioId) {
      return isSuperAdmin() || isMemberOfStudio(studioId) || isLegacyPrimaryStudio(studioId);
    }

    function isOwnerUid(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function tenantDocAccessible() {
      return isSuperAdmin()
        || (resource.data.keys().hasAny(['studioId'])
          && canAccessStudio(resource.data.studioId));
    }

    function tenantCreateAccessible() {
      return isSuperAdmin()
        || (request.resource.data.keys().hasAny(['studioId'])
          && canAccessStudio(request.resource.data.studioId));
    }

    function tenantStudioIdUnchanged() {
      return request.resource.data.studioId == resource.data.studioId;
    }

    function membershipIdMatches(membershipId) {
      return membershipId == request.auth.uid + '_' + request.resource.data.studioId;
    }

    function canSelfAssignMembership() {
      return request.resource.data.studioId == request.auth.uid
        || (
          exists(/databases/$(database)/documents/studios/$(request.resource.data.studioId))
          && get(/databases/$(database)/documents/studios/$(request.resource.data.studioId)).data.ownerId == request.auth.uid
        );
    }

    // ---------- CONFIG GLOBALE (solo Super Admin) ----------
    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isSuperAdmin();
    }

    // ---------- ADMIN NOTES ----------
    match /adminNotes/{noteId} {
      allow read, write: if isSuperAdmin();
    }

    // ---------- SUBSCRIPTION PAYMENTS (storico revenue) ----------
    match /subscriptionPayments/{paymentId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ---------- EMAIL VERIFICATION (solo Cloud Functions / Admin SDK) ----------
    match /emailVerificationCodes/{userId} {
      allow read, write: if false;
    }

    match /studioSecrets/{studioId} {
      allow read, write: if false;
    }

    match /arubaCounters/{studioId} {
      allow read, write: if false;
    }

    // ---------- USERS ----------
    match /users/{userId} {
      allow read: if isSuperAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if isOwnerUid(userId)
        && request.resource.data.studioId == userId
        && request.resource.data.keys().hasAll(['studioId', 'email', 'name', 'role', 'lang']);
      allow update: if isSuperAdmin() || (
        isOwnerUid(userId)
        && request.resource.data.studioId == resource.data.studioId
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
      );
      allow delete: if isSuperAdmin() || isOwnerUid(userId);

      match /installations/{installationId} {
        allow read: if isSuperAdmin() || isOwnerUid(userId);

        allow create: if isOwnerUid(userId)
          && request.resource.data.userId == userId
          && request.resource.data.platform in ['desktop', 'web']
          && request.resource.data.keys().hasAll(['userId', 'platform', 'os', 'appVersion']);

        allow update: if isSuperAdmin() || (
          isOwnerUid(userId)
          && resource.data.userId == userId
          && request.resource.data.userId == userId
          && request.resource.data.platform in ['desktop', 'web']
        );

        allow delete: if isSuperAdmin() || (isOwnerUid(userId) && resource.data.userId == userId);
      }
    }

    // ---------- MEMBERSHIPS ----------
    match /memberships/{membershipId} {
      allow read: if isSuperAdmin() || (signedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSuperAdmin() || (
        signedIn()
        && request.resource.data.userId == request.auth.uid
        && membershipIdMatches(membershipId)
        && request.resource.data.keys().hasAll(['userId', 'studioId', 'role'])
        && request.resource.data.role in ['owner', 'admin', 'technician', 'cashier']
        && canSelfAssignMembership()
      );

      allow update: if isSuperAdmin() || (
        signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.studioId == resource.data.studioId
      );

      allow delete: if isSuperAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    // ---------- STUDIOS ----------
    match /studios/{studioId} {
      allow read: if canAccessStudio(studioId);

      allow create: if signedIn() && (
        isSuperAdmin()
        || (
          isOwnerUid(studioId)
          && request.resource.data.keys().hasAll(['name', 'email'])
        )
        || (
          request.resource.data.ownerId == request.auth.uid
          && request.resource.data.keys().hasAll(['name', 'email', 'ownerId'])
        )
      );

      allow update: if canAccessStudio(studioId);

      allow delete: if isSuperAdmin() || (
        canAccessStudio(studioId)
        && (
          isLegacyPrimaryStudio(studioId)
          || (
            isMemberOfStudio(studioId)
            && get(membershipDocPath(studioId)).data.role == 'owner'
          )
        )
      );
    }

    match /studios/{studioId}/{subcollection}/{docId} {
      allow read, write: if canAccessStudio(studioId);
    }

    // ---------- DATI TENANT (campo studioId sul documento) ----------

    match /categories/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /products/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /repairs/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /clients/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /suppliers/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /documents/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /payments/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /paymentResources/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /stockMovements/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /devices/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /agents/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /warehouses/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }

    match /priceLists/{docId} {
      allow read: if tenantDocAccessible();
      allow create: if tenantCreateAccessible();
      allow update: if tenantDocAccessible() && (isSuperAdmin() || tenantStudioIdUnchanged());
      allow delete: if tenantDocAccessible();
    }
  }
}
