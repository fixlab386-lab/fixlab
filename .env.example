# Variabili d'ambiente per rilascio desktop FixLab
# Copia in .env.local (non committare) o imposta nel sistema.

# Obbligatorio per npm run release:* (publish su GitHub Releases)
GH_TOKEN=

# Opzionale: override repository publish (default da package.json)
# GH_PUBLISH_OWNER=fixlab386
# GH_PUBLISH_REPO=fixlab

# Opzionale: firma codice Windows (Authenticode)
# CSC_LINK=C:\secrets\fixlab-codesign.pfx
# CSC_KEY_PASSWORD=
